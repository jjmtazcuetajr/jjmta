<section class="contact-section" id="contact">
  <div class="container">
    <div class="intro">
      <h2 class="heading">Let's Work Together</h2>
      <p class="tagline">
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of
        your visions. Let's create something amazing together.
      </p>
    </div>
    <form class="contact-form" novalidate>
      <div class="formgroup">
        <label class="label" for="name">Name</label>
        <input
          class="inputbox"
          id="name"
          name="name"
          autocomplete="name"
          placeholder="Your name"
          required
          type="text"
          aria-describedby="name-feedback"
        />
        <span class="errortext" id="name-feedback" aria-live="polite"></span>
      </div>
      <div class="formgroup">
        <label class="label" for="email">Email</label>
        <input
          class="inputbox"
          id="email"
          name="email"
          autocomplete="email"
          placeholder="test@example.com"
          required
          type="email"
          aria-describedby="email-feedback"
        />
        <span class="errortext" id="email-feedback" aria-live="polite"></span>
      </div>
      <div class="formgroup">
        <label class="label" for="message">Message</label>
        <textarea
          class="messagebox"
          id="message"
          name="message"
          placeholder="Tell me about your project or idea..."
          required
          rows="5"
          aria-describedby="message-feedback"></textarea>
        <span class="errortext" id="message-feedback" aria-live="polite"></span>
      </div>
      <button class="sendbutton" type="submit">
        Send Message
        <svg
          class="icon"
          height="24"
          width="24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"
          ></path>
          <path d="m21.854 2.147-10.94 10.939"></path>
        </svg>
      </button>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector('.contact-form')

  if (form && form instanceof HTMLFormElement) {
    const formTextFields = form.querySelectorAll('input, textarea')
    const submitButton = form.querySelector('button[type="submit"]')

    formTextFields.forEach((textField) => {
      if (textField instanceof HTMLInputElement || textField instanceof HTMLTextAreaElement) {
        textField.addEventListener('blur', () => normalizeInput(textField))
        textField.addEventListener('input', () => {
          if (textField.validity.valid) clearError(textField)
        })
        textField.addEventListener('keydown', (e) => {
          if (
            e instanceof KeyboardEvent &&
            e.key === 'Enter' &&
            textField instanceof HTMLInputElement
          )
            normalizeInput(textField)
        })
      }
    })

    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      formTextFields.forEach((textField) => {
        if (textField instanceof HTMLInputElement || textField instanceof HTMLTextAreaElement) {
          if (!textField.validity.valid) showError(textField)
        }
      })

      // stop form submission here if any text field is invalid
      const isValid = Array.from(formTextFields).every((textField) => {
        if (textField instanceof HTMLInputElement || textField instanceof HTMLTextAreaElement) {
          return textField.validity.valid
        }
        return true
      })
      if (!isValid) return

      disableSubmitButton(submitButton)
      disableTextFields(formTextFields)

      await new Promise((r) => setTimeout(r, 2000)) // simulate API call

      clearAndEnableTextFields(formTextFields)
      enableSubmitButton(submitButton)
    })
  }

  /**
   * Normalizes the value of a text input or textarea element by:
   * - Clearing the field if it only contains whitespace.
   * - Collapsing multiple consecutive spaces into single spaces.
   * - For textareas only: collapsing multiple consecutive newlines into single newlines.
   * - Trimming leading and trailing whitespace.
   *
   * @param element - The text input or textarea element to normalize.
   */
  function normalizeInput(element: HTMLInputElement | HTMLTextAreaElement) {
    const value = element.value
    const isTextarea = element instanceof HTMLTextAreaElement

    // if only whitespace characters (spaces and/or newlines), clear the text field
    if (/^\s*$/.test(value)) {
      element.value = ''
      return
    }

    let normalized = value

    if (isTextarea) {
      // normalize each line: collapse multiple spaces into one
      normalized = normalized
        .split('\n')
        .map((line) => line.replace(/ +/g, ' '))
        .join('\n')

      // collapse multiple consecutive newlines into one
      normalized = normalized.replace(/\n{2,}/g, '\n')
    } else {
      // for text inputs: collapse multiple spaces into one
      normalized = normalized.replace(/ +/g, ' ')
    }

    // trim leading/trailing spaces and newlines
    normalized = normalized.trim()

    element.value = normalized
  }

  /**
   * Retrieves the validation error message for a given input element.
   *
   * Checks if the input has a missing value or invalid type and returns the browser's
   * built-in validation message. Returns an empty string if the input is valid.
   *
   * @param input - The text input or textarea element to check.
   * @returns The validation message if the input is invalid, or an empty string if valid.
   */
  function getErrorMessage(input: HTMLInputElement | HTMLTextAreaElement): string {
    if (input.validity.valueMissing || input.validity.typeMismatch) return input.validationMessage
    return ''
  }

  /**
   * Displays validation error feedback for a given input element.
   *
   * This function:
   * - Displays the error message in the input's sibling span element.
   * - Adds the `-invalid` CSS class to visually indicate an error state.
   * - Sets `aria-invalid="true"` for accessibility.
   *
   * @param input - The text input or textarea element to show an error for.
   */
  function showError(input: HTMLInputElement | HTMLTextAreaElement) {
    const span = input.nextElementSibling
    if (span && span instanceof HTMLSpanElement) {
      span.textContent = getErrorMessage(input)
      span.style.display = 'inline'
      input.classList.add('-invalid')
      input.setAttribute('aria-invalid', 'true')
    }
  }

  /**
   * Clears validation error feedback for a given input element.
   *
   * This function:
   * - Clears the error message displayed in the input's sibling span element.
   * - Removes the `-invalid` CSS class to restore the valid state appearance.
   * - Removes the `aria-invalid` attribute for accessibility.
   *
   * @param input - The text input or textarea element to clear the error for.
   */
  function clearError(input: HTMLInputElement | HTMLTextAreaElement) {
    const span = input.nextElementSibling
    if (span && span instanceof HTMLSpanElement) {
      span.textContent = ''
      span.removeAttribute('style')
      input.classList.remove('-invalid')
      input.removeAttribute('aria-invalid')
    }
  }

  /**
   * Disables all input and textarea elements in the provided NodeList.
   * Elements that are not `HTMLInputElement` or `HTMLTextAreaElement` are ignored.
   *
   * @param textFields - A NodeList of DOM elements to iterate over.
   */
  function disableTextFields(textFields: NodeListOf<Element>) {
    textFields.forEach((textField) => {
      if (textField instanceof HTMLInputElement || textField instanceof HTMLTextAreaElement)
        textField.disabled = true
    })
  }

  /**
   * Clears and re-enables all input and textarea elements in the provided NodeList.
   * Elements that are not `HTMLInputElement` or `HTMLTextAreaElement` are ignored.
   *
   * @param textFields - A NodeList of DOM elements to iterate over.
   */
  function clearAndEnableTextFields(textFields: NodeListOf<Element>) {
    textFields.forEach((textField) => {
      if (textField instanceof HTMLInputElement || textField instanceof HTMLTextAreaElement) {
        textField.value = ''
        textField.disabled = false
      }
    })
  }

  /**
   * Disables a submit button and updates its appearance to indicate a loading state.
   *
   * If the provided element is a valid `HTMLButtonElement`, this function will:
   * - Disable the button to prevent further clicks.
   * - Update the button's text content to `'Sending...'`.
   * - Replace the button's SVG icon with an animated spinning indicator.
   *
   * @param button The DOM element representing the submit button. Must be an `HTMLButtonElement` to apply changes.
   */
  function disableSubmitButton(button: Element | null) {
    if (button && button instanceof HTMLButtonElement) {
      button.disabled = true
      button.childNodes[0].textContent = 'Sending...'

      const buttonIcon = button.querySelector('svg')
      if (buttonIcon && buttonIcon instanceof SVGSVGElement) {
        buttonIcon.setAttribute('stroke-width', '3')
        buttonIcon.innerHTML = `<path d="M21 12a9 9 0 1 1-6.219-8.56">
            <animateTransform attributeName="transform" dur="1s" from="0 12 12" repeatCount="indefinite" to="360 12 12" type="rotate" />
          </path>`
      }
    }
  }

  /**
   * Re-enables a submit button and restores its original appearance.
   *
   * If the provided element is a valid `HTMLButtonElement`, this function will:
   * - Re-enable the button to allow clicks.
   * - Restore the button's text content to `'Send Message'`.
   * - Replace the button's SVG icon with the original send icon.
   *
   * @param button The DOM element representing the submit button. Must be an `HTMLButtonElement` to apply changes.
   */
  function enableSubmitButton(button: Element | null) {
    if (button && button instanceof HTMLButtonElement) {
      button.disabled = false
      button.childNodes[0].textContent = 'Send Message'

      const buttonIcon = button.querySelector('svg')
      if (buttonIcon && buttonIcon instanceof SVGSVGElement) {
        buttonIcon.setAttribute('stroke-width', '2')
        buttonIcon.innerHTML = `<path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z" />
          <path d="m21.854 2.147-10.94 10.939" />`
      }
    }
  }
</script>
