---
import type { ImageMetadata } from 'astro'
import projectsData from '../../data/projects.json'
import ProjectCard from './ProjectCard.astro'

/**
 * A record mapping image file paths to their lazy-loading functions.
 * Each function returns a promise that resolves to an object with the image metadata.
 */
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpg,jpeg,png,webp,JPG,PNG}',
)

/**
 * Array of project data with their corresponding image metadata resolved and attached.
 * Each project object now includes an `imageData` property containing the loaded image metadata.
 */
const resolvedItems = await Promise.all(
  projectsData.map(async (project) => {
    // retrieve the lazy loader for the project's image
    const loader = images[project.imagePath]
    if (!loader) throw new Error(`Image not found at path: ${project.imagePath}`)

    // load the image module and extract the default export (ImageMetadata)
    const module = await loader()
    return { ...project, imageData: module.default }
  }),
)
---

<section class="projects-section" id="projects">
  <h2 class="heading">Projects</h2>
  {resolvedItems.map(async (project) => <ProjectCard {...project} />)}
</section>
