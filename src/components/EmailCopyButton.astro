<email-copy-button>
  <button class="btn" type="button" aria-label="Copy email address to clipboard">
    <svg
      class="email-icon"
      height="24"
      width="24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
      <rect height="16" width="20" rx="2" x="2" y="4"></rect>
    </svg>
    <svg
      class="check-icon"
      height="24"
      width="24"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="M20 6 9 17l-5-5"></path>
    </svg>
  </button>
  <div class="tooltip" role="status" aria-live="polite"></div>
</email-copy-button>

<script>
  const USER = 'azcuetajjmt'
  const DOMAIN = 'gmail'
  const TLD = 'com'

  class EmailCopyButton extends HTMLElement {
    resetTimer: ReturnType<typeof setTimeout> | null
    button: HTMLButtonElement | null
    tooltip: HTMLDivElement | null

    constructor() {
      super()

      this.resetTimer = null
      this.button = this.querySelector('button')
      this.tooltip = this.querySelector('.tooltip')

      if (this.button) {
        this.button.addEventListener('click', () => this.copyEmail())
      }
    }

    /**
     * A getter that constructs the email address by concatenating the {@link USER|user}, {@link DOMAIN|domain}, and {@link TLD|top-level domain (TLD)}.
     */
    get _email() {
      const emailAddress = `${USER}@${DOMAIN}.${TLD}`
      return emailAddress
    }

    /**
     * Copies the email address to the clipboard and provides visual feedback.
     *
     * On success, displays a success message, toggles the copied state, and schedules cleanup.
     * On failure, displays an error message. Both feedback messages auto-hide after a set duration.
     */
    async copyEmail() {
      const email = this._email

      try {
        await navigator.clipboard.writeText(email)
        this.setCopied(true)
        this.showTooltip('Email copied!')
        this.resetTimer = setTimeout(() => {
          this.hideTooltip()
          this.setCopied(false)
        }, 2500)
      } catch {
        this.showTooltip('Copy failed.', true)
        this.resetTimer = setTimeout(() => this.hideTooltip(), 3000)
      }
    }

    /**
     * Displays a tooltip message with optional error styling.
     *
     * Clears any pending reset timer, applies error styling if needed, and triggers CSS transitions
     * by removing and re-adding the visible class.
     *
     * @param message - The text to display in the tooltip.
     * @param isError - Whether to apply error styling (default: false).
     */
    showTooltip(message: string, isError = false) {
      if (this.resetTimer) {
        clearTimeout(this.resetTimer)
      }

      if (this.tooltip) {
        const t = this.tooltip
        t.textContent = message
        t.classList.toggle('-error', isError)
        t.classList.remove('-visible')
        void t.offsetWidth // trigger a reflow to restart CSS transitions
        t.classList.add('-visible')
      }
    }

    /**
     * Hides the tooltip by removing its visible state.
     */
    hideTooltip() {
      if (this.tooltip) {
        this.tooltip.classList.remove('-visible')
      }
    }

    /**
     * Updates the button's visual and accessibility state based on the copied status.
     *
     * Toggles the `-copied` CSS class for visual styling and updates the aria-label
     * to reflect whether the email has been successfully copied.
     *
     * @param copied - True for copied state, false for default state.
     */
    setCopied(copied: boolean) {
      if (this.button) {
        this.button.classList.toggle('-copied', copied)
        this.button.setAttribute(
          'aria-label',
          copied ? 'Email copied!' : 'Copy email address to clipboard',
        )
      }
    }
  }

  customElements.define('email-copy-button', EmailCopyButton)
</script>
