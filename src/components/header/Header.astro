---
import SocialLink from './SocialLink.astro'
---

<header class="home-section" id="home">
  <h1 class="greeting">Hi, I'm Michael Azcueta</h1>
  <p class="summary">
    I build things for the web. A lifelong learner dedicated to crafting seamless user experiences
    and robust backend systems.
  </p>
  <div class="social-links">
    <SocialLink
      ariaLabel="Visit my LinkedIn profile"
      iconName="linkedin"
      url="https://linkedin.com"
    >
      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
      ></path>
      <rect height="12" width="4" x="2" y="9"></rect>
      <circle cx="4" cy="4" r="2"></circle>
    </SocialLink>
    <SocialLink ariaLabel="Visit my GitHub profile" iconName="github" url="https://github.com">
      <path
        d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
      ></path>
      <path d="M9 18c-4.51 2-5-2-7-2"></path>
    </SocialLink>
    <SocialLink
      ariaLabel="Send me an email"
      iconName="mail"
      isMailto
      url="mailto:azcuetajjmt@gmail.com"
    >
      <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
      <rect height="16" width="20" rx="2" x="2" y="4"></rect>
    </SocialLink>
  </div>
</header>
