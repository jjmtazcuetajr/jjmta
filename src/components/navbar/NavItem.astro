---
interface Props {
  identifier: string
  iconName: string
}

const { identifier, iconName } = Astro.props
---

<li>
  <a href={`#${identifier}`} class="navlink">
    <span class="icon">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class={`lucide lucide-${iconName}-icon lucide-${iconName}`}
      >
        <slot />
      </svg>
    </span>
    <span class="text">{identifier}</span>
  </a>
</li>
